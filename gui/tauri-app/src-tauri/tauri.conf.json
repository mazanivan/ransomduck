{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RansomDuck",
  "version": "0.1.0",
  "identifier": "com.ransomduck.tray",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RansomDuck",
        "width": 640,
        "height": 480,
        "visible": true,
        "decorations": true,
        "center": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
